{
    "name": "claude-code-terminal-tabs",
    "displayName": "Terminal Tabs — Hotkeys, Focus & Claude Code",
    "description": "Browser-like Ctrl/Cmd+1..9 hotkeys to switch terminals. Reliable focus on terminal click (no more accidentally typing into Quick Open). One-click new Claude Code sessions via hotkey, terminal profile, and command palette.",
    "version": "0.1.6",
    "publisher": "FoxyBOA",
    "license": "MIT",
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/FoxyBOA/claude-code-terminal-tabs"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": ["Other"],
    "keywords": [
        "terminal",
        "tabs",
        "terminal tabs",
        "switch",
        "hotkey",
        "browser",
        "focus",
        "quick-switch",
        "multi-terminal",
        "cmd+1",
        "ctrl+1",
        "claude",
        "claude-code",
        "session"
    ],
    "activationEvents": ["onStartupFinished"],
    "main": "./extension.js",
    "contributes": {
        "configuration": {
            "title": "Claude Code Terminal Tabs",
            "properties": {
                "claudeCodeTerminalTabs.enforceFocusOnSwitch": {
                    "type": "boolean",
                    "default": true,
                    "description": "When the active terminal changes, force focus into the terminal input (and dismiss any open quick-pick)."
                },
                "claudeCodeTerminalTabs.dismissQuickPick": {
                    "type": "boolean",
                    "default": true,
                    "description": "Before forcing terminal focus, close any open Quick Open / command palette."
                },
                "claudeCodeTerminalTabs.onlyClaudeTerminals": {
                    "type": "boolean",
                    "default": true,
                    "description": "Only enforce focus for terminals running Claude Code. Detection: fast regex on terminal name first; if no match, the process tree is scanned for a `claude` descendant (cached per terminal). Set to false to apply the focus-bulldozer to every terminal regardless of what it runs."
                },
                "claudeCodeTerminalTabs.claudePattern": {
                    "type": "string",
                    "default": "claude|·|\\*",
                    "description": "Regex used as the fast-path detector for Claude Code terminals (matched against terminal name, case-insensitive). If a terminal name does not match, the process tree is scanned as fallback."
                },
                "claudeCodeTerminalTabs.launchCommand": {
                    "type": "string",
                    "default": "claude",
                    "description": "Command to run when starting a new Claude Code session."
                }
            }
        },
        "commands": [
            {
                "command": "claudeCodeTerminalTabs.newSession",
                "title": "Claude Code: New Terminal Session",
                "category": "Claude Code Terminal Tabs"
            },
            {
                "command": "claudeCodeTerminalTabs.focusActive",
                "title": "Focus Active Terminal",
                "category": "Claude Code Terminal Tabs"
            },
            {
                "command": "claudeCodeTerminalTabs.toggleEnforce",
                "title": "Toggle Enforce Focus On Switch",
                "category": "Claude Code Terminal Tabs"
            }
        ],
        "keybindings": [
            { "key": "ctrl+1", "mac": "cmd+1", "command": "workbench.action.terminal.focusAtIndex1" },
            { "key": "ctrl+2", "mac": "cmd+2", "command": "workbench.action.terminal.focusAtIndex2" },
            { "key": "ctrl+3", "mac": "cmd+3", "command": "workbench.action.terminal.focusAtIndex3" },
            { "key": "ctrl+4", "mac": "cmd+4", "command": "workbench.action.terminal.focusAtIndex4" },
            { "key": "ctrl+5", "mac": "cmd+5", "command": "workbench.action.terminal.focusAtIndex5" },
            { "key": "ctrl+6", "mac": "cmd+6", "command": "workbench.action.terminal.focusAtIndex6" },
            { "key": "ctrl+7", "mac": "cmd+7", "command": "workbench.action.terminal.focusAtIndex7" },
            { "key": "ctrl+8", "mac": "cmd+8", "command": "workbench.action.terminal.focusAtIndex8" },
            { "key": "ctrl+9", "mac": "cmd+9", "command": "workbench.action.terminal.focusAtIndex9" },
            { "key": "ctrl+shift+0", "mac": "cmd+shift+0", "command": "claudeCodeTerminalTabs.newSession" }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "claudeCodeTerminalTabs.newSession",
                    "when": "view == terminal",
                    "group": "1_run"
                }
            ]
        },
        "terminal": {
            "profiles": [
                {
                    "id": "claudeCodeTerminalTabs.profile",
                    "title": "Claude Code",
                    "icon": "rocket"
                }
            ]
        }
    },
    "scripts": {
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@vscode/vsce": "^2.22.0"
    }
}
